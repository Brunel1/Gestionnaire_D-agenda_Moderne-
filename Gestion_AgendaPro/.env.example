# Configuration de l'API Cloud pour la synchronisation
# Remplacez les valeurs par vos propres configurations
CLOUD_API_URL=https://api.agenda-service.com/v1
CLOUD_API_KEY=votre_cle_api_secrete_ici

# Intervalle de synchronisation en secondes (3600 = 1 heure)
SYNC_INTERVAL=3600

# Clé secrète pour l'authentification JWT (générez une clé sécurisée)
SECRET_KEY=votre_cle_secrete_jwt_ici
